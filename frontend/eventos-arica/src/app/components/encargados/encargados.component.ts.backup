import { Component, OnInit } from '@angular/core';
import { CommonModule } from '@angular/common';
import { FormsModule } from '@angular/forms';
import { EncargadosService } from '../../services/encargados.service';
import { Usuario, RegistroUsuarioDTO, UpdateEncargadoDTO } from '../../models/api.models';

interface Encargado {
  idUsuario: number;
  nombre: string;
  apellido: string;
  correo: string;
  telefono: string;
  rol: string;
  contrasena?: string; // Solo para crear
}

@Component({
  selector: 'app-encargados',
  standalone: true,
  imports: [CommonModule, FormsModule],
  template: `
    <div class="ml-64 min-h-screen bg-gradient-to-br from-arica-blue via-blue-700 to-cyan-500 p-8">
      <div class="max-w-7xl mx-auto">
        
        <!-- Header con botón crear -->
        <div class="bg-white rounded-lg shadow-2xl overflow-hidden mb-8">
          <div class="h-2 overflow-hidden">
            <img src="images/cuatro_colores.png" alt="" class="w-full h-full object-cover">
          </div>
          <div class="p-8 flex justify-between items-center">
            <div>
              <h1 class="text-4xl font-bold text-arica-blue mb-2">Gestión de Encargados</h1>
              <p class="text-gray-600">Administra los responsables de eventos municipales</p>
            </div>
            <button
              (click)="abrirModalCrear()"
              class="bg-arica-green hover:bg-green-600 text-white font-bold py-3 px-6 rounded-lg transition-colors flex items-center gap-2 shadow-lg"
            >
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/>
              </svg>
              Crear Encargado
            </button>
          </div>
        </div>

        <!-- Búsqueda y filtros -->
        <div class="bg-white rounded-lg shadow-lg p-6 mb-8">
          <div class="flex flex-wrap gap-4">
            <div class="flex-1 min-w-[300px]">
              <div class="flex items-center bg-gray-100 rounded-lg px-4 py-3">
                <svg class="w-5 h-5 text-gray-500" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/>
                </svg>
                <input
                  type="text"
                  [(ngModel)]="busqueda"
                  placeholder="Buscar por nombre, email o departamento..."
                  class="flex-1 bg-transparent outline-none text-gray-700 ml-3"
                >
              </div>
            </div>
            
            <div class="flex gap-2">
              <button
                *ngFor="let filtro of filtrosEstado"
                (click)="filtroEstadoActivo = filtro.valor"
                [class.bg-arica-blue]="filtroEstadoActivo === filtro.valor"
                [class.text-white]="filtroEstadoActivo === filtro.valor"
                [class.bg-gray-200]="filtroEstadoActivo !== filtro.valor"
                [class.text-gray-700]="filtroEstadoActivo !== filtro.valor"
                class="px-4 py-2 rounded-lg font-semibold transition-colors"
              >
                {{ filtro.label }}
              </button>
            </div>
          </div>
        </div>

        <!-- Lista de encargados -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <div
            *ngFor="let encargado of encargadosFiltrados"
            class="bg-white rounded-lg shadow-xl overflow-hidden hover:shadow-2xl transition-all hover:scale-105 cursor-pointer"
          >
            <!-- Header con foto y estado -->
            <div class="relative bg-gradient-to-br from-arica-blue to-blue-600 p-6 text-white">
              <div class="absolute top-3 right-3">
                <span
                  [class]="getEstadoClass(encargado.estado)"
                  class="px-3 py-1 rounded-full text-xs font-bold"
                >
                  {{ encargado.estado }}
                </span>
              </div>
              
              <div class="flex items-center gap-4">
                <!-- Avatar -->
                <div class="w-20 h-20 bg-white/20 backdrop-blur-sm rounded-full flex items-center justify-center overflow-hidden">
                  <img
                    *ngIf="encargado.foto"
                    [src]="encargado.foto"
                    [alt]="encargado.nombre"
                    class="w-full h-full object-cover"
                  >
                  <svg *ngIf="!encargado.foto" class="w-12 h-12 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/>
                  </svg>
                </div>
                
                <div>
                  <h3 class="text-xl font-bold">{{ encargado.nombre }} {{ encargado.apellido }}</h3>
                  <p class="text-white/80 text-sm">{{ encargado.cargo }}</p>
                </div>
              </div>
            </div>

            <!-- Contenido -->
            <div class="p-6">
              <div class="space-y-3 mb-4">
                <div class="flex items-center gap-2 text-sm text-gray-600">
                  <svg class="w-4 h-4 text-arica-blue" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
                    <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
                  </svg>
                  <span class="truncate">{{ encargado.email }}</span>
                </div>
                
                <div class="flex items-center gap-2 text-sm text-gray-600">
                  <svg class="w-4 h-4 text-arica-blue" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
                  </svg>
                  <span>{{ encargado.telefono }}</span>
                </div>

                <div class="flex items-center gap-2 text-sm text-gray-600">
                  <svg class="w-4 h-4 text-arica-blue" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h8a2 2 0 012 2v12a1 1 0 110 2h-3a1 1 0 01-1-1v-2a1 1 0 00-1-1H9a1 1 0 00-1 1v2a1 1 0 01-1 1H4a1 1 0 110-2V4zm3 1h2v2H7V5zm2 4H7v2h2V9zm2-4h2v2h-2V5zm2 4h-2v2h2V9z" clip-rule="evenodd"/>
                  </svg>
                  <span>{{ encargado.departamento }}</span>
                </div>
              </div>

              <!-- Botones de acción -->
              <div class="flex gap-2">
                <button
                  (click)="verDetalle(encargado)"
                  class="flex-1 bg-arica-blue hover:bg-arica-blue-dark text-white font-semibold py-2 px-4 rounded-lg transition-colors flex items-center justify-center gap-2"
                >
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/>
                    <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/>
                  </svg>
                  Ver
                </button>
                <button
                  (click)="abrirModalEditar(encargado)"
                  class="flex-1 bg-arica-yellow hover:bg-yellow-500 text-white font-semibold py-2 px-4 rounded-lg transition-colors flex items-center justify-center gap-2"
                >
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"/>
                  </svg>
                  Editar
                </button>
                <button
                  (click)="confirmarEliminar(encargado)"
                  class="bg-arica-coral hover:bg-red-600 text-white font-semibold p-2 rounded-lg transition-colors"
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Mensaje cuando no hay encargados -->
        <div *ngIf="encargadosFiltrados.length === 0" class="bg-white rounded-lg shadow-xl p-12 text-center">
          <svg class="w-24 h-24 mx-auto text-gray-400 mb-4" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"/>
          </svg>
          <h3 class="text-2xl font-bold text-gray-700 mb-2">No se encontraron encargados</h3>
          <p class="text-gray-500">Intenta ajustar los filtros o crear un nuevo encargado</p>
        </div>

      </div>
    </div>

    <!-- Modal Crear/Editar -->
    <div
      *ngIf="mostrarModal"
      class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4"
      (click)="cerrarModal()"
    >
      <div
        (click)="$event.stopPropagation()"
        class="bg-white rounded-lg shadow-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto"
      >
        <div class="h-2 overflow-hidden">
          <img src="images/cuatro_colores.png" alt="" class="w-full h-full object-cover">
        </div>
        
        <div class="p-8">
          <h2 class="text-3xl font-bold text-arica-blue mb-6">
            {{ modoEdicion ? 'Editar Encargado' : 'Crear Nuevo Encargado' }}
          </h2>

          <form class="space-y-6">
            <!-- Nombre y Apellido -->
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-arica-blue font-bold mb-2">Nombre *</label>
                <input
                  type="text"
                  [(ngModel)]="encargadoForm.nombre"
                  name="nombre"
                  placeholder="Ej: Juan"
                  class="w-full px-4 py-3 bg-arica-cyan/30 rounded-lg outline-none focus:ring-2 focus:ring-arica-blue"
                >
              </div>

              <div>
                <label class="block text-arica-blue font-bold mb-2">Apellido *</label>
                <input
                  type="text"
                  [(ngModel)]="encargadoForm.apellido"
                  name="apellido"
                  placeholder="Ej: Pérez"
                  class="w-full px-4 py-3 bg-arica-cyan/30 rounded-lg outline-none focus:ring-2 focus:ring-arica-blue"
                >
              </div>
            </div>

            <!-- Email y Teléfono -->
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-arica-blue font-bold mb-2">Email *</label>
                <input
                  type="email"
                  [(ngModel)]="encargadoForm.email"
                  name="email"
                  placeholder="ejemplo@arica.cl"
                  class="w-full px-4 py-3 bg-arica-cyan/30 rounded-lg outline-none focus:ring-2 focus:ring-arica-blue"
                >
              </div>

              <div>
                <label class="block text-arica-blue font-bold mb-2">Teléfono *</label>
                <input
                  type="tel"
                  [(ngModel)]="encargadoForm.telefono"
                  name="telefono"
                  placeholder="+56 9 1234 5678"
                  class="w-full px-4 py-3 bg-arica-cyan/30 rounded-lg outline-none focus:ring-2 focus:ring-arica-blue"
                >
              </div>
            </div>

            <!-- Cargo y Departamento -->
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-arica-blue font-bold mb-2">Cargo *</label>
                <input
                  type="text"
                  [(ngModel)]="encargadoForm.cargo"
                  name="cargo"
                  placeholder="Ej: Coordinador de Eventos"
                  class="w-full px-4 py-3 bg-arica-cyan/30 rounded-lg outline-none focus:ring-2 focus:ring-arica-blue"
                >
              </div>

              <div>
                <label class="block text-arica-blue font-bold mb-2">Departamento *</label>
                <select
                  [(ngModel)]="encargadoForm.departamento"
                  name="departamento"
                  class="w-full px-4 py-3 bg-arica-cyan/30 rounded-lg outline-none focus:ring-2 focus:ring-arica-blue"
                >
                  <option value="">Seleccionar departamento</option>
                  <option value="Deportes">Deportes</option>
                  <option value="Cultura">Cultura</option>
                  <option value="Educación">Educación</option>
                  <option value="Salud">Salud</option>
                  <option value="Turismo">Turismo</option>
                  <option value="Recreación">Recreación</option>
                </select>
              </div>
            </div>

            <!-- Estado -->
            <div>
              <label class="block text-arica-blue font-bold mb-2">Estado</label>
              <select
                [(ngModel)]="encargadoForm.estado"
                name="estado"
                class="w-full px-4 py-3 bg-arica-cyan/30 rounded-lg outline-none focus:ring-2 focus:ring-arica-blue"
              >
                <option value="Activo">Activo</option>
                <option value="Inactivo">Inactivo</option>
              </select>
            </div>

            <!-- Foto URL -->
            <div>
              <label class="block text-arica-blue font-bold mb-2">URL de Foto</label>
              <input
                type="text"
                [(ngModel)]="encargadoForm.foto"
                name="foto"
                placeholder="https://ejemplo.com/foto.jpg"
                class="w-full px-4 py-3 bg-arica-cyan/30 rounded-lg outline-none focus:ring-2 focus:ring-arica-blue"
              >
              <p class="text-xs text-gray-500 mt-1">Opcional: Ingresa la URL de una foto de perfil</p>
            </div>

            <!-- Botones -->
            <div class="flex gap-4 pt-4">
              <button
                type="button"
                (click)="guardarEncargado()"
                class="flex-1 bg-arica-blue hover:bg-arica-blue-dark text-white font-bold py-3 px-6 rounded-lg transition-colors"
              >
                {{ modoEdicion ? 'Guardar Cambios' : 'Crear Encargado' }}
              </button>
              <button
                type="button"
                (click)="cerrarModal()"
                class="flex-1 bg-gray-300 hover:bg-gray-400 text-gray-700 font-bold py-3 px-6 rounded-lg transition-colors"
              >
                Cancelar
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- Modal Confirmar Eliminar -->
    <div
      *ngIf="mostrarModalEliminar"
      class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4"
      (click)="cancelarEliminar()"
    >
      <div
        (click)="$event.stopPropagation()"
        class="bg-white rounded-lg shadow-2xl max-w-md w-full p-8"
      >
        <div class="text-center">
          <div class="mx-auto flex items-center justify-center h-16 w-16 rounded-full bg-red-100 mb-4">
            <svg class="h-10 w-10 text-red-600" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-2">¿Eliminar encargado?</h3>
          <p class="text-gray-600 mb-6">
            ¿Estás seguro de que deseas eliminar a <strong>{{ encargadoAEliminar?.nombre }} {{ encargadoAEliminar?.apellido }}</strong>? 
            Esta acción no se puede deshacer.
          </p>
          <div class="flex gap-4">
            <button
              (click)="eliminarEncargado()"
              class="flex-1 bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-6 rounded-lg transition-colors"
            >
              Eliminar
            </button>
            <button
              (click)="cancelarEliminar()"
              class="flex-1 bg-gray-300 hover:bg-gray-400 text-gray-700 font-bold py-3 px-6 rounded-lg transition-colors"
            >
              Cancelar
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Modal Ver Detalle -->
    <div
      *ngIf="mostrarModalDetalle && encargadoDetalle"
      class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4"
      (click)="cerrarDetalle()"
    >
      <div
        (click)="$event.stopPropagation()"
        class="bg-white rounded-lg shadow-2xl max-w-3xl w-full max-h-[90vh] overflow-y-auto"
      >
        <div class="h-2 overflow-hidden">
          <img src="images/cuatro_colores.png" alt="" class="w-full h-full object-cover">
        </div>
        
        <!-- Header con foto -->
        <div class="relative bg-gradient-to-br from-arica-blue to-blue-600 p-8 text-white">
          <button
            (click)="cerrarDetalle()"
            class="absolute top-4 right-4 text-white/70 hover:text-white transition-colors"
          >
            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
            </svg>
          </button>

          <div class="flex items-center gap-6">
            <!-- Avatar grande -->
            <div class="w-32 h-32 bg-white/20 backdrop-blur-sm rounded-full flex items-center justify-center overflow-hidden">
              <img
                *ngIf="encargadoDetalle.foto"
                [src]="encargadoDetalle.foto"
                [alt]="encargadoDetalle.nombre"
                class="w-full h-full object-cover"
              >
              <svg *ngIf="!encargadoDetalle.foto" class="w-20 h-20 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/>
              </svg>
            </div>
            
            <div>
              <h2 class="text-4xl font-bold mb-2">{{ encargadoDetalle.nombre }} {{ encargadoDetalle.apellido }}</h2>
              <p class="text-xl text-white/90 mb-2">{{ encargadoDetalle.cargo }}</p>
              <span
                [class]="getEstadoClass(encargadoDetalle.estado)"
                class="px-3 py-1 rounded-full text-sm font-bold"
              >
                {{ encargadoDetalle.estado }}
              </span>
            </div>
          </div>
        </div>

        <div class="p-8">
          <h3 class="text-xl font-bold text-arica-blue mb-4">Información de Contacto</h3>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
            <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-lg">
              <svg class="w-6 h-6 text-arica-blue mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
                <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
              </svg>
              <div>
                <p class="text-sm text-gray-500">Email</p>
                <p class="font-semibold text-gray-700">{{ encargadoDetalle.email }}</p>
              </div>
            </div>

            <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-lg">
              <svg class="w-6 h-6 text-arica-blue mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
              </svg>
              <div>
                <p class="text-sm text-gray-500">Teléfono</p>
                <p class="font-semibold text-gray-700">{{ encargadoDetalle.telefono }}</p>
              </div>
            </div>

            <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-lg">
              <svg class="w-6 h-6 text-arica-blue mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h8a2 2 0 012 2v12a1 1 0 110 2h-3a1 1 0 01-1-1v-2a1 1 0 00-1-1H9a1 1 0 00-1 1v2a1 1 0 01-1 1H4a1 1 0 110-2V4zm3 1h2v2H7V5zm2 4H7v2h2V9zm2-4h2v2h-2V5zm2 4h-2v2h2V9z" clip-rule="evenodd"/>
              </svg>
              <div>
                <p class="text-sm text-gray-500">Departamento</p>
                <p class="font-semibold text-gray-700">{{ encargadoDetalle.departamento }}</p>
              </div>
            </div>

            <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-lg">
              <svg class="w-6 h-6 text-arica-blue mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M6 6V5a3 3 0 013-3h2a3 3 0 013 3v1h2a2 2 0 012 2v3.57A22.952 22.952 0 0110 13a22.95 22.95 0 01-8-1.43V8a2 2 0 012-2h2zm2-1a1 1 0 011-1h2a1 1 0 011 1v1H8V5zm1 5a1 1 0 011-1h.01a1 1 0 110 2H10a1 1 0 01-1-1z" clip-rule="evenodd"/>
                <path d="M2 13.692V16a2 2 0 002 2h12a2 2 0 002-2v-2.308A24.974 24.974 0 0110 15c-2.796 0-5.487-.46-8-1.308z"/>
              </svg>
              <div>
                <p class="text-sm text-gray-500">Cargo</p>
                <p class="font-semibold text-gray-700">{{ encargadoDetalle.cargo }}</p>
              </div>
            </div>
          </div>

          <!-- Botón de editar -->
          <div class="mt-6">
            <button
              (click)="editarDesdeDetalle()"
              class="w-full bg-arica-yellow hover:bg-yellow-500 text-white font-bold py-3 px-6 rounded-lg transition-colors flex items-center justify-center gap-2"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"/>
              </svg>
              Editar Encargado
            </button>
          </div>
        </div>
      </div>
    </div>
  `,
  styles: []
})
export class EncargadosComponent implements OnInit {
  busqueda = '';
  filtroEstadoActivo = 'Todos';
  mostrarModal = false;
  mostrarModalEliminar = false;
  mostrarModalDetalle = false;
  modoEdicion = false;
  encargadoDetalle: Encargado | null = null;
  encargadoAEliminar: Encargado | null = null;

  // Estado de carga y mensajes
  cargando = false;
  mensajeError = '';
  mensajeExito = '';

  filtrosEstado = [
    { label: 'Todos', valor: 'Todos' },
    { label: 'Activo', valor: 'Activo' },
    { label: 'Inactivo', valor: 'Inactivo' }
  ];

