      estado: 'Activo'
    }
  ];

  get encargadosFiltrados(): Encargado[] {
    let filtered = this.encargados;

    // Filtrar por estado
    if (this.filtroEstadoActivo !== 'Todos') {
      filtered = filtered.filter(e => e.estado === this.filtroEstadoActivo);
    }

    // Filtrar por búsqueda
    if (this.busqueda.trim()) {
      const search = this.busqueda.toLowerCase();
      filtered = filtered.filter(e =>
        e.nombre.toLowerCase().includes(search) ||
        e.apellido.toLowerCase().includes(search) ||
        e.email.toLowerCase().includes(search) ||
        e.departamento.toLowerCase().includes(search)
      );
    }

    return filtered;
  }

  getEstadoClass(estado: string): string {
    return estado === 'Activo'
      ? 'bg-green-500 text-white'
      : 'bg-gray-500 text-white';
  }

  abrirModalCrear(): void {
    this.modoEdicion = false;
    this.encargadoForm = {
      id: 0,
      nombre: '',
      apellido: '',
      email: '',
      telefono: '',
      cargo: '',
      departamento: '',
      foto: '',
      estado: 'Activo'
    };
    this.mostrarModal = true;
  }

  abrirModalEditar(encargado: Encargado): void {
    this.modoEdicion = true;
    this.encargadoForm = { ...encargado };
    this.mostrarModal = true;
  }

  cerrarModal(): void {
    this.mostrarModal = false;
  }

  guardarEncargado(): void {
    if (!this.encargadoForm.nombre || !this.encargadoForm.apellido ||
      !this.encargadoForm.email || !this.encargadoForm.telefono ||
      !this.encargadoForm.cargo || !this.encargadoForm.departamento) {
      alert('Por favor completa los campos obligatorios');
      return;
    }

    if (this.modoEdicion) {
      // Actualizar encargado existente
      const index = this.encargados.findIndex(e => e.id === this.encargadoForm.id);
      if (index !== -1) {
        this.encargados[index] = { ...this.encargadoForm };
      }
    } else {
      // Crear nuevo encargado
      const nuevoId = Math.max(...this.encargados.map(e => e.id), 0) + 1;
      this.encargados.push({ ...this.encargadoForm, id: nuevoId });
    }

    this.cerrarModal();
  }

  confirmarEliminar(encargado: Encargado): void {
    this.encargadoAEliminar = encargado;
    this.mostrarModalEliminar = true;
  }

  eliminarEncargado(): void {
    if (this.encargadoAEliminar) {
      this.encargados = this.encargados.filter(e => e.id !== this.encargadoAEliminar!.id);
      this.cancelarEliminar();
    }
  }

  cancelarEliminar(): void {
    this.mostrarModalEliminar = false;
    this.encargadoAEliminar = null;
  }

  verDetalle(encargado: Encargado): void {
    this.encargadoDetalle = encargado;
    this.mostrarModalDetalle = true;
  }

  cerrarDetalle(): void {
    this.mostrarModalDetalle = false;
    this.encargadoDetalle = null;
  }

  editarDesdeDetalle(): void {
    if (this.encargadoDetalle) {
      this.cerrarDetalle();
      this.abrirModalEditar(this.encargadoDetalle);
    }
  }
}
